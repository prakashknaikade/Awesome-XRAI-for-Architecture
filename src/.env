# GitHub Configuration for validation and deployment
# GITHUB_TOKEN=your_personal_access_token_here
REPO_OWNER=prakashknaikade
REPO_NAME=Awesome-XRAI-for-Architecture

# Flask Configuration (if using Flask for local development)
# FLASK_SECRET_KEY=your-secret-key-here

# GitHub OAuth (for advanced features like user authentication)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Deployment settings
ENVIRONMENT=production
AUTO_DEPLOY=false  # Set to true only after manual review
REQUIRE_REVIEW=true

# Validation settings
VALIDATE_URLS=true
TIMEOUT_SECONDS=30
MAX_PAPERS_PER_PR=10

## Optional: Custom domain
# CUSTOM_DOMAIN=

## Optional: Analytics
#GOOGLE_ANALYTICS_ID=